# Hugging Face
HF_TOKEN=hf_xxx
HF_HOME=/mnt/cache/huggingface
HF_HUB_CACHE=/mnt/cache/huggingface/hub

# Weights & Biases
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=tinyaya-mimi-tts
WANDB_ENTITY=your-entity
WANDB_DIR=/mnt/cache/wandb
WANDB_ARTIFACT_DIR=/mnt/cache/wandb/artifacts

# Torch / temp caches
TORCH_HOME=/mnt/cache/torch
TMPDIR=/mnt/cache/tmp

# Distributed defaults
NPROC_PER_NODE=8
NNODES=1
NODE_RANK=0
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500
